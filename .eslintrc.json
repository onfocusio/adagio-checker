{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jest": true
  },
  "extends": ["eslint:recommended", "plugin:prettier/recommended"],
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "globals": {
    "ADAGIO": "readonly",
    "ADAGIO_KEY": "readonly"
  },
  "rules": {
    "quotes": ["error", "single", { "avoidEscape": true, "allowTemplateLiterals": false }],
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "eqeqeq": "error",
    "prefer-const": "error",
    "no-var": "error",
    "no-undef": "error",
    "no-console": "warn",
    "semi": ["error", "always"]
  }
}
